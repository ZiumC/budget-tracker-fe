          "minLength": "3",
          "maxLength": "150"
        },
        "price": {
          "minValue": "0",
          "maxLength": "8"
        },
        "refund": {
          "minValue": "0",
          "maxLength": "8"
        },
        "comment": {
          "minLength": "3",
          "maxLength": "512"
        }
      },
      "incomeModal": {
        "placeholder": "0.00",
