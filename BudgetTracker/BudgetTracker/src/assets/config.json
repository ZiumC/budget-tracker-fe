            "applyForApi": true
          },
          {
            "name": "estimated",
            "value": "estimated",
            "displayDirections": true,
            "applyForApi": true
          },
          {
            "name": "actual",
            "value": "realPrice",
            "displayDirections": true,
            "applyForApi": true
          },
          {
            "name": "paid first",
            "value": "paidFirst",
            "displayDirections": false,
            "applyForApi": true
          }
        ],
        "paymentCategoryTypes": [
          {
            "name": "date updated",
            "value": "dateUpdated",
            "displayDirections": true,
