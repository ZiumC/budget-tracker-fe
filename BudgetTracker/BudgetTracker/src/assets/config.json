      "order": {
        "incomeTypes": [
          {
            "name": "date updated",
            "displayDirections": true
          },
          {
            "name": "wage",
            "displayDirections": true
          },
          {
            "name": "surplus first",
            "displayDirections": false
          }
        ],
        "paymentTypes": [
          {
            "name": "date updated",
            "displayDirections": true
          },
          {
            "name": "price",
            "displayDirections": true
          },
          {
            "name": "refund",
            "displayDirections": true
          },
          {
            "name": "paid first",
            "displayDirections": false
          },
          {
            "name": "real cost",
            "displayDirections": true
          }
        ],
        "excludedTypes": [
          {
            "name": "paid first",
            "displayDirections": false
          },
          {
            "name": "surplus first",
            "displayDirections": false
          }
