{
  "app": {
    "animation": {
      "duration": {
        "default": 500,
        "short": 300,
        "long": 1500
      }
    },
    "timer": {
      "duration": {
        "default": 25,
        "short": 12
      }
    },
    "form": {
      "messages": {
        "required": "Field is required",
        "minValue": "Minimum value is {0}",
        "minLength": "Minimum length are {0} characters",
        "maxLength": "Maximum length are {0} characters",
        "invalid": "{0} is invalid",
        "invalidFormat": "Invalid {0} format",
        "notFound": "{0} not found",
        "range": "{0} range is invalid",
        "equal": "{0} in both dates should be equal",
        "alreadyDefined": "Month already defined"
