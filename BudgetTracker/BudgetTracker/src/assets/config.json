          "minLength": "3",
          "maxLength": "150"
        },
        "wage": {
          "minValue": "0",
          "maxLength": "8"
        }
      },
      "budgetModal": {
        "name": {
          "minLength": "3",
          "maxLength": "150"
        }
      },
      "regex": {
        "money": "^[0-9]*\\.[0-9]{1,2}$|^[0-9]{1,}"
      }
