        "passNotMatch": "Passwords not equal",
        "passTooWeak": "Password is too weak",
        "typeahead": {
          "notfound": "Categories not found",
          "notExist": "Categories not exist, add them in categories page"
        }
      },
      "categoryModal": {
        "name": {
          "minLength": "3",
          "maxLength": "30"
        },
        "description": {
          "minLength": "3",
          "maxLength": "100"
        },
        "needsName": "needs",
        "wantsName": "wants",
        "savingsName": "savings"
      },
      "paymentModal": {
        "placeholder": "0.00",
        "name": {
          "minLength": "3",
          "maxLength": "150"
        },
        "price": {
          "minValue": "0",
          "maxLength": "8"
        },
        "refund": {
          "minValue": "0",
          "maxLength": "8"
        },
        "comment": {
          "minLength": "3",
          "maxLength": "512"
        },
        "commentAssignment": {
          "minLength": "3",
          "maxLength": "255"
        }
      },
      "incomeModal": {
        "placeholder": "0.00",
        "name": {
          "minLength": "3",
          "maxLength": "150"
        },
        "number": {
          "minValue": "0",
          "maxLength": "8"
        }
      },
      "budgetModal": {
        "name": {
          "minLength": "3",
          "maxLength": "150"
        }
      },
      "loginForm": {
        "emailOrLogin": {
          "minLength": "3",
          "maxLength": "150"
        },
        "password": {
          "minLength": "3",
          "maxLength": "20"
        },
        "code": {
          "minLength": "6",
          "maxLength": "6"
        }
      },
      "registerForm": {
        "email": {
          "minLength": "3",
          "maxLength": "150"
        },
        "login": {
          "minLength": "3",
          "maxLength": "150"
        },
        "password": {
          "minLength": "3",
          "maxLength": "20"
        },
        "code": {
          "minLength": "9",
          "maxLength": "9"
        }
      },
      "temporaryPassword": {
        "minLength": "12",
        "maxLength": "12"
      },
      "regex": {
        "money": "^[0-9]*\\.[0-9]{1,2}$|^[0-9]{1,}",
        "loginOrEmail": "(?:[a-z0-9!#$%&'*+\\x2f=?^_`\\x7b-\\x7d~\\x2d]+(?:\\.[a-z0-9!#$%&'*+\\x2f=?^_`\\x7b-\\x7d~\\x2d]+)*|\"(?:[\\x01-\\x08\\x0b\\x0c\\x0e-\\x1f\\x21\\x23-\\x5b\\x5d-\\x7f]|\\\\[\\x01-\\x09\\x0b\\x0c\\x0e-\\x7f])*\")@(?:(?:[a-z0-9](?:[a-z0-9\\x2d]*[a-z0-9])?\\.)+[a-z0-9](?:[a-z0-9\\x2d]*[a-z0-9])?|\\[(?:(?:(2(5[0-5]|[0-4][0-9])|1[0-9][0-9]|[1-9]?[0-9]))\\.){3}(?:(2(5[0-5]|[0-4][0-9])|1[0-9][0-9]|[1-9]?[0-9])|[a-z0-9\\x2d]*[a-z0-9]:(?:[\\x01-\\x08\\x0b\\x0c\\x0e-\\x1f\\x21-\\x5a\\x53-\\x7f]|\\\\[\\x01-\\x09\\x0b\\x0c\\x0e-\\x7f])+)\\])|([a-zA-Z0-9])",
        "email": "(?:[a-z0-9!#$%&'*+\\x2f=?^_`\\x7b-\\x7d~\\x2d]+(?:\\.[a-z0-9!#$%&'*+\\x2f=?^_`\\x7b-\\x7d~\\x2d]+)*|\"(?:[\\x01-\\x08\\x0b\\x0c\\x0e-\\x1f\\x21\\x23-\\x5b\\x5d-\\x7f]|\\\\[\\x01-\\x09\\x0b\\x0c\\x0e-\\x7f])*\")@(?:(?:[a-z0-9](?:[a-z0-9\\x2d]*[a-z0-9])?\\.)+[a-z0-9](?:[a-z0-9\\x2d]*[a-z0-9])?|\\[(?:(?:(2(5[0-5]|[0-4][0-9])|1[0-9][0-9]|[1-9]?[0-9]))\\.){3}(?:(2(5[0-5]|[0-4][0-9])|1[0-9][0-9]|[1-9]?[0-9])|[a-z0-9\\x2d]*[a-z0-9]:(?:[\\x01-\\x08\\x0b\\x0c\\x0e-\\x1f\\x21-\\x5a\\x53-\\x7f]|\\\\[\\x01-\\x09\\x0b\\x0c\\x0e-\\x7f])+)\\])",
        "password": {
          "upperCase": "(?=.*[A-Z].*[A-Z])",
          "lowerCase": "(?=.*[a-z].*[a-z].*[a-z])",
          "specialCharacter": "(?=.*[!@#$&*])",
          "digits": "(?=.*[0-9].*[0-9])",
          "length": ".{3,20}"
        },
        "codes": {
          "otp": "^[0-9]{6,6}$",
          "emailConfirm": "^[0-9]{9,9}$"
        }
      }
    },
    "request": {
